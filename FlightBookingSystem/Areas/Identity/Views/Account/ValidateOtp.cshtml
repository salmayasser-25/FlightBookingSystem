@model OtpViewModel
@{
    ViewData["Title"] = "OTP Verification";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0a0a1a;
        }

        .auth-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .auth-card {
            background: #111827;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        .auth-logo {
            font-size: 48px;
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-card h1 {
            color: #fff;
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 4px;
        }

        .auth-card p.subtitle {
            color: #888;
            text-align: center;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .form-label {
            color: #ccc;
            font-size: 14px;
            font-weight: 500;
        }

        .form-control {
            background: #1f2937;
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 12px;
            text-align: center;
            font-family: monospace;
        }

            .form-control:focus {
                background: #1f2937;
                border-color: #0d6efd;
                color: #fff;
                box-shadow: 0 0 0 3px rgba(13,110,253,0.15);
            }

            .form-control::placeholder {
                color: #374151;
                letter-spacing: 8px;
                font-size: 22px;
            }

        .btn-auth {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
            transition: opacity .2s;
        }

            .btn-auth:hover {
                opacity: 0.9;
            }

        .btn-resend {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            background: transparent;
            color: #888;
            font-size: 14px;
            cursor: pointer;
            margin-top: 10px;
            transition: all .2s;
        }

            .btn-resend:hover {
                border-color: #0d6efd;
                color: #4da6ff;
            }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

            .auth-footer a {
                color: #4da6ff;
                text-decoration: none;
            }

                .auth-footer a:hover {
                    text-decoration: underline;
                }

        .text-danger {
            font-size: 12px;
        }

        .otp-hint {
            background: rgba(13,110,253,0.1);
            border: 1px solid rgba(13,110,253,0.2);
            border-radius: 10px;
            padding: 12px 16px;
            color: #4da6ff;
            font-size: 13px;
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">🔐</div>
        <h1>OTP Verification</h1>
        <p class="subtitle">Enter the 6-digit code sent to your email</p>

        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info py-2 small">@TempData["InfoMessage"]</div>
        }

        <div class="otp-hint">
            📧 Check your inbox at <strong>@Model.Email</strong>
        </div>

        <form asp-action="ValidateOtp" asp-area="Identity" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Email" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-4">
                <label asp-for="OtpCode" class="form-label">Verification Code</label>
                <input asp-for="OtpCode" class="form-control" placeholder="------"
                       maxlength="6" inputmode="numeric" autocomplete="one-time-code" id="otpInput" />
                <span asp-validation-for="OtpCode" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-auth">Verify Now ✅</button>
        </form>

        <form asp-action="ResendOtp" asp-area="Identity" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input name="email" type="hidden" value="@Model.Email" />
            <button type="submit" class="btn-resend">🔄 Resend Code</button>
        </form>

        <div class="auth-footer">
            <a asp-action="Login" asp-area="Identity" asp-controller="Account">← Back to Login</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('otpInput').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });
    </script>
}
