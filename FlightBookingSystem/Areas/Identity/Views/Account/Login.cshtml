@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0a0a1a;
        }

        .auth-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .auth-card {
            background: #111827;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        .auth-logo {
            font-size: 48px;
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-card h1 {
            color: #fff;
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 4px;
        }

        .auth-card p.subtitle {
            color: #888;
            text-align: center;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .form-label {
            color: #ccc;
            font-size: 14px;
            font-weight: 500;
        }

        .form-control {
            background: #1f2937;
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 10px;
            padding: 12px 16px;
        }

            .form-control:focus {
                background: #1f2937;
                border-color: #0d6efd;
                color: #fff;
                box-shadow: 0 0 0 3px rgba(13,110,253,0.15);
            }

            .form-control::placeholder {
                color: #4b5563;
            }

        .input-group .form-control {
            border-radius: 10px 0 0 10px;
        }

        .btn-eye {
            background: #1f2937;
            border: 1px solid rgba(255,255,255,0.1);
            border-left: none;
            color: #888;
            padding: 0 16px;
            border-radius: 0 10px 10px 0;
            cursor: pointer;
            font-size: 18px;
        }

            .btn-eye:hover {
                color: #fff;
            }

        .forgot-link {
            color: #4da6ff;
            font-size: 13px;
            text-decoration: none;
            float: right;
            margin-top: 8px;
        }

            .forgot-link:hover {
                text-decoration: underline;
            }

        .form-check-label {
            color: #ccc;
            font-size: 14px;
        }

        .btn-auth {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
            transition: opacity .2s;
        }

            .btn-auth:hover {
                opacity: 0.9;
            }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

            .auth-footer a {
                color: #4da6ff;
                text-decoration: none;
            }

                .auth-footer a:hover {
                    text-decoration: underline;
                }

        .text-danger {
            font-size: 12px;
        }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">✈️</div>
        <h1>Welcome Back</h1>
        <p class="subtitle">Sign in to your AeroFly account</p>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success py-2 small">@TempData["SuccessMessage"]</div>
        }

        <form asp-action="Login" asp-area="Identity" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">📧 Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="Password" class="form-label">🔑 Password</label>
                <div class="input-group">
                    <input asp-for="Password" class="form-control" id="passwordInput" placeholder="Your password" />
                    <button type="button" class="btn-eye" onclick="togglePassword()">👁</button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                    <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                </div>
                <a asp-action="ForgotPassword" asp-area="Identity" asp-controller="Account"
                   class="forgot-link">Forgot password?</a>
            </div>

            <button type="submit" class="btn-auth">Sign In ✈️</button>
        </form>

        <div class="auth-footer">
            Don't have an account?
            <a asp-action="Register" asp-area="Identity" asp-controller="Account">Create one</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePassword() {
            const inp = document.getElementById('passwordInput');
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
    </script>
}
