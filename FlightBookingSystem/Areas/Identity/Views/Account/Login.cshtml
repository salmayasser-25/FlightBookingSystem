@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

@section Styles {
    <!-- Google Fonts: Gelasio + Inter (from update-fonts-final.js / update-logo.js) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Gelasio:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />
    <style>
        /* Logo styling (from update-logo.js / final-logo-cleanup.js) */
        .logo-icon-custom {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
        }
        .logo-icon-custom img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
        }
        .footer-logo-icon {
            background: transparent;
        }
        .footer-logo-icon img {
            width: 44px;
            height: 44px;
            object-fit: contain;
        }
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3, h4, h5, h6,
        .logo-main, .footer-logo-name {
            font-family: 'Gelasio', serif;
        }

        /* Sticky navbar effect (driven by script.js .scrolled toggle) */
        .site-header {
            transition: background 0.3s ease, box-shadow 0.3s ease, padding 0.3s ease;
        }
        .site-header.scrolled {
            background: rgba(10, 37, 64, 0.95);
            backdrop-filter: blur(8px);
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.18);
        }

        /* Fade-up animation (paired with IntersectionObserver in script.js) */
        .fade-on-scroll {
            opacity: 0;
            transform: translateY(25px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

        .auth-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background-image: url('https://images.unsplash.com/photo-1556388158-158ea5ccacbd?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80');
            background-size: cover;
            background-position: center;
            position: relative;
            padding: 120px 0 60px;
        }
        .auth-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, rgba(10, 37, 64, 0.9) 0%, rgba(26, 58, 95, 0.8) 100%);
        }
        .auth-card {
            background: var(--white);
            border-radius: 24px;
            padding: 40px;
            box-shadow: var(--shadow-xl);
            position: relative;
            z-index: 2;
        }
        .auth-card h2 {
            color: var(--primary-deep-blue);
            font-weight: 800;
            margin-bottom: 8px;
        }
        .auth-card p {
            color: var(--gray-600);
            font-size: 0.9rem;
            margin-bottom: 24px;
        }
        .auth-input-group { margin-bottom: 20px; }
        .auth-input-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 8px;
            display: block;
        }
        .auth-input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid var(--gray-200);
            border-radius: 12px;
            font-size: 0.95rem;
            transition: all var(--transition-fast);
            background: var(--gray-50);
        }
        .auth-input:focus {
            outline: none;
            border-color: var(--primary-sky);
            box-shadow: 0 0 0 3px rgba(45, 122, 159, 0.1);
            background: var(--white);
        }
        .btn-auth {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary-sky), var(--primary-navy));
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            transition: all var(--transition-fast);
        }
        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            background: linear-gradient(135deg, var(--primary-navy), var(--primary-sky));
        }
        .auth-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 0.9rem;
            color: var(--gray-600);
        }
        .auth-footer a {
            color: var(--primary-sky);
            font-weight: 600;
            text-decoration: none;
        }
        .auth-footer a:hover { text-decoration: underline; }
        .field-error { color: #dc3545; font-size: 0.78rem; margin-top: 4px; display: block; }
    </style>
}

<section class="auth-section">
    <div class="auth-overlay"></div>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5 col-xl-4">
                <div class="auth-card animate-fade-up">
                    <h2>Welcome Back</h2>
                    <p>Sign in to manage your flights and rewards.</p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success py-2 small">@TempData["SuccessMessage"]</div>
                    }

                    <form asp-action="Login" asp-area="Identity" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="auth-input-group">
                            <label asp-for="Email">Email Address</label>
                            <input asp-for="Email" class="auth-input" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>

                        <div class="auth-input-group">
                            <label asp-for="Password" class="d-flex justify-content-between">
                                <span>Password</span>
                                <a asp-action="ForgotPassword" asp-area="Identity" asp-controller="Account"
                                   style="font-size: 0.75rem; color: var(--primary-sky); text-decoration: none;">Forgot?</a>
                            </label>
                            <input asp-for="Password" class="auth-input" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>

                        <div class="auth-input-group d-flex align-items-center" style="margin-bottom: 12px;">
                            <input asp-for="RememberMe" class="form-check-input me-2" type="checkbox" />
                            <label asp-for="RememberMe" class="mb-0" style="font-size: 0.85rem;">Remember me</label>
                        </div>

                        <button type="submit" class="btn-auth mt-2">Sign In</button>
                    </form>

                    <div class="auth-footer">
                        Don't have an account?
                        <a asp-action="Register" asp-area="Identity" asp-controller="Account">Join AeroFly+</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        /* Page-scoped behaviors mirrored from wwwroot/js/script.js */
        (function () {
            "use strict";

            // ---------- Sticky Navbar ----------
            const header = document.querySelector('.site-header');
            function handleScroll() {
                if (!header) return;
                if (window.scrollY > 30) header.classList.add('scrolled');
                else header.classList.remove('scrolled');
            }
            window.addEventListener('scroll', handleScroll);
            handleScroll();

            // ---------- Smooth Scroll for Anchor Links ----------
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    const href = this.getAttribute('href');
                    if (href && href !== '#') {
                        const target = document.querySelector(href);
                        if (target) {
                            e.preventDefault();
                            target.scrollIntoView({ behavior: 'smooth' });
                        }
                    }
                });
            });

            // ---------- IntersectionObserver Fade-Up ----------
            const animatedElements = document.querySelectorAll('.fade-on-scroll, .auth-card');
            if ('IntersectionObserver' in window) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.style.opacity = '1';
                            entry.target.style.transform = 'translateY(0)';
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });

                animatedElements.forEach(el => {
                    if (!el.classList.contains('animate-fade-up')) {
                        el.style.opacity = '0';
                        el.style.transform = 'translateY(25px)';
                        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                    }
                    observer.observe(el);
                });
            }

            // ---------- Newsletter (footer) ----------
            const newsletterBtn = document.querySelector('.newsletter-form button');
            const newsletterInput = document.querySelector('.newsletter-form input');
            if (newsletterBtn) {
                newsletterBtn.addEventListener('click', function () {
                    const email = newsletterInput?.value.trim();
                    if (email && email.includes('@@')) {
                        alert('Thank you for subscribing! Premium deals will be sent to ' + email);
                        newsletterInput.value = '';
                    } else if (email) {
                        alert('Please enter a valid email address.');
                    }
                });
            }

            console.log('AeroFly UI Ready - Sign In page');
        })();
    </script>
}
