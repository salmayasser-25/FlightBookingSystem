@model ConfirmEmailViewModel
@{
    ViewData["Title"] = "Confirm Email";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0a0a1a;
        }

        .auth-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .auth-card {
            background: #111827;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            text-align: center;
        }

        .auth-logo {
            font-size: 64px;
            margin-bottom: 16px;
        }

        .auth-card h1 {
            color: #fff;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .auth-card p.subtitle {
            color: #888;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .status-box {
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 24px;
            font-size: 15px;
            font-weight: 500;
        }

        .status-success {
            background: rgba(40,167,69,0.1);
            border: 1px solid rgba(40,167,69,0.3);
            color: #28a745;
        }

        .status-error {
            background: rgba(220,53,69,0.1);
            border: 1px solid rgba(220,53,69,0.3);
            color: #dc3545;
        }

        .otp-hint {
            background: rgba(13,110,253,0.1);
            border: 1px solid rgba(13,110,253,0.2);
            border-radius: 10px;
            padding: 12px 16px;
            color: #4da6ff;
            font-size: 13px;
            margin-bottom: 24px;
        }

        .btn-auth {
            display: inline-block;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: opacity .2s;
        }

            .btn-auth:hover {
                opacity: 0.9;
                color: #fff;
            }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

            .auth-footer a {
                color: #4da6ff;
                text-decoration: none;
            }

                .auth-footer a:hover {
                    text-decoration: underline;
                }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">@(Model.IsSuccess ? "✅" : "❌")</div>
        <h1>Email Confirmation</h1>
        <p class="subtitle">AeroFly Account Verification</p>

        <div class="status-box @(Model.IsSuccess ? "status-success" : "status-error")">
            @Model.Message
        </div>

        @if (Model.IsSuccess)
        {
            <div class="otp-hint">
                📧 An OTP code has been sent to your inbox — please check your email and verify your account.
            </div>
            <a asp-action="ValidateOtp" asp-area="Identity" asp-controller="Account"
               asp-route-email="@Model.Email" class="btn-auth">
                Enter OTP Code 🔐
            </a>
        }

        <div class="auth-footer">
            <a asp-action="Login" asp-area="Identity" asp-controller="Account">← Back to Login</a>
        </div>
    </div>
</div>
