@model RegisterViewModel
@{
    ViewData["Title"] = "Join AeroFly+";
}

@section Styles {
    <style>
        .auth-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background-image: url('https://images.unsplash.com/photo-1542296332-2e4473faf563?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80');
            background-size: cover;
            background-position: center;
            position: relative;
            padding: 120px 0 60px;
        }
        .auth-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, rgba(10, 37, 64, 0.9) 0%, rgba(26, 58, 95, 0.8) 100%);
        }
        .auth-card {
            background: var(--white);
            border-radius: 24px;
            padding: 40px;
            box-shadow: var(--shadow-xl);
            position: relative;
            z-index: 2;
        }
        .auth-card h2 {
            color: var(--primary-deep-blue);
            font-weight: 800;
            margin-bottom: 8px;
        }
        .auth-card p {
            color: var(--gray-600);
            font-size: 0.9rem;
            margin-bottom: 24px;
        }
        .auth-input-group { margin-bottom: 20px; }
        .auth-input-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 8px;
            display: block;
        }
        .auth-input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid var(--gray-200);
            border-radius: 12px;
            font-size: 0.95rem;
            transition: all var(--transition-fast);
            background: var(--gray-50);
        }
        .auth-input:focus {
            outline: none;
            border-color: var(--primary-sky);
            box-shadow: 0 0 0 3px rgba(45, 122, 159, 0.1);
            background: var(--white);
        }
        .btn-auth {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--accent-gold), #B8942E);
            color: var(--primary-deep-blue);
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            transition: all var(--transition-fast);
        }
        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            background: linear-gradient(135deg, #B8942E, var(--accent-gold));
        }
        .auth-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 0.9rem;
            color: var(--gray-600);
        }
        .auth-footer a {
            color: var(--primary-sky);
            font-weight: 600;
            text-decoration: none;
        }
        .auth-footer a:hover { text-decoration: underline; }
        .row-inputs { display: flex; gap: 16px; }
        .row-inputs .auth-input-group { flex: 1; }
        .field-error { color: #dc3545; font-size: 0.78rem; margin-top: 4px; display: block; }
    </style>
}

<section class="auth-section">
    <div class="auth-overlay"></div>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="auth-card animate-fade-up">
                    <h2>Join AeroFly+</h2>
                    <p>Earn points, enjoy flexible bookings, and travel in style.</p>

                    <form asp-action="Register" asp-area="Identity" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="row-inputs">
                            <div class="auth-input-group">
                                <label asp-for="FName">First Name</label>
                                <input asp-for="FName" class="auth-input" placeholder="e.g. John" />
                                <span asp-validation-for="FName" class="field-error"></span>
                            </div>
                            <div class="auth-input-group">
                                <label asp-for="LName">Last Name</label>
                                <input asp-for="LName" class="auth-input" placeholder="e.g. Doe" />
                                <span asp-validation-for="LName" class="field-error"></span>
                            </div>
                        </div>

                        <div class="auth-input-group">
                            <label asp-for="Email">Email Address</label>
                            <input asp-for="Email" class="auth-input" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>

                        <div class="auth-input-group">
                            <label asp-for="Password">Password</label>
                            <input asp-for="Password" class="auth-input" type="password" placeholder="Create a strong password" />
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>

                        <button type="submit" class="btn-auth mt-2">Create Account</button>
                    </form>

                    <div class="auth-footer">
                        Already a member?
                        <a asp-action="Login" asp-area="Identity" asp-controller="Account">Sign In</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
