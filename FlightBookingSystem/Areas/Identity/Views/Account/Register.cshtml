@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0a0a1a;
        }

        .auth-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .auth-card {
            background: #111827;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 520px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        .auth-logo {
            font-size: 48px;
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-card h1 {
            color: #fff;
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 4px;
        }

        .auth-card p.subtitle {
            color: #888;
            text-align: center;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .form-label {
            color: #ccc;
            font-size: 14px;
            font-weight: 500;
        }

        .form-control {
            background: #1f2937;
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 10px;
            padding: 12px 16px;
        }

            .form-control:focus {
                background: #1f2937;
                border-color: #0d6efd;
                color: #fff;
                box-shadow: 0 0 0 3px rgba(13,110,253,0.15);
            }

            .form-control::placeholder {
                color: #4b5563;
            }

        .btn-auth {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            margin-top: 8px;
            transition: opacity .2s;
        }

            .btn-auth:hover {
                opacity: 0.9;
            }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

            .auth-footer a {
                color: #4da6ff;
                text-decoration: none;
            }

                .auth-footer a:hover {
                    text-decoration: underline;
                }

        .text-danger {
            font-size: 12px;
        }

        .password-strength {
            height: 4px;
            background: #1f2937;
            border-radius: 4px;
            margin-top: 8px;
            overflow: hidden;
        }

        .strength-fill {
            height: 100%;
            width: 0%;
            border-radius: 4px;
            transition: width .3s, background .3s;
        }

        .strength-text {
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">✈️</div>
        <h1>Create Account</h1>
        <p class="subtitle">Join the AeroFly flight booking system</p>

        <form asp-action="Register" asp-area="Identity" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="FName" class="form-label">First Name</label>
                    <input asp-for="FName" class="form-control" placeholder="First name" />
                    <span asp-validation-for="FName" class="text-danger"></span>
                </div>
                <div class="col-6">
                    <label asp-for="LName" class="form-label">Last Name</label>
                    <input asp-for="LName" class="form-control" placeholder="Last name" />
                    <span asp-validation-for="LName" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password"
                       placeholder="At least 8 characters" id="pass1" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="password-strength">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <small id="strengthText" class="strength-text"></small>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password"
                       placeholder="Re-enter your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-auth">Create Account 🚀</button>
        </form>

        <div class="auth-footer">
            Already have an account?
            <a asp-action="Login" asp-area="Identity" asp-controller="Account">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('pass1').addEventListener('input', function () {
            const val = this.value;
            const fill = document.getElementById('strengthFill');
            const text = document.getElementById('strengthText');
            let strength = 0;
            if (val.length >= 8) strength++;
            if (/[A-Z]/.test(val)) strength++;
            if (/[0-9]/.test(val)) strength++;
            if (/[^A-Za-z0-9]/.test(val)) strength++;
            const colors = ['#dc3545','#fd7e14','#ffc107','#28a745'];
            const labels = ['Weak','Fair','Good','Strong'];
            if (val.length > 0) {
                fill.style.width = (strength * 25) + '%';
                fill.style.background = colors[strength - 1] || '#dc3545';
                text.textContent = 'Password strength: ' + (labels[strength - 1] || 'Too weak');
                text.style.color = colors[strength - 1] || '#dc3545';
            } else {
                fill.style.width = '0%';
                text.textContent = '';
            }
        });
    </script>
}
