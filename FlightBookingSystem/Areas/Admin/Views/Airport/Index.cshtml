@model List<Airport>

@{
    ViewData["Title"] = "Airports";
    ViewData["PageId"] = "airports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <!-- CARD WRAPPER -->
    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-body p-4">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                    <h4 class="fw-bold mb-1">Airports</h4>
                    <small class="text-muted">Manage all airports in the system</small>
                </div>

                <a href="/Admin/Airport/Create"
                   class="btn btn-dark rounded-pill px-4">
                    <i class="bi bi-plus-lg me-1"></i> Add Airport
                </a>

            </div>

            <!-- TABLE -->
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Airport</th>
                            <th>IATA</th>
                            <th>Location</th>
                            <th>Coordinates</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var a in Model)
                            {
                                <tr>

                                    <!-- AIRPORT NAME -->
                                    <td>
                                        <div class="fw-bold">@a.Name</div>
                                        <small class="text-muted">@a.Country</small>
                                    </td>

                                    <!-- CODE -->
                                    <td>
                                        <span class="badge bg-dark">@a.IataCode</span>
                                    </td>

                                    <!-- CITY -->
                                    <td>
                                        @a.City
                                    </td>

                                    <!-- COORDINATES -->
                                    <td class="text-muted small">
                                        @a.Latitude , @a.Longitude
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-end">

                                        <div class="d-flex justify-content-end gap-2">

                                            <a href="/Admin/Airport/Edit/@a.AirportId"
                                               class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                Edit
                                            </a>

                                            <form method="post"
                                                  action="/Admin/Airport/Delete"
                                                  onsubmit="return confirm('Delete this airport?');">

                                                <input type="hidden" name="id" value="@a.AirportId" />

                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                    Delete
                                                </button>

                                            </form>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    No airports found
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

</div>