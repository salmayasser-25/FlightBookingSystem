@model DashboardVM

@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageId"] = "dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Admin-Dashboardadmin.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Gelasio:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 CSS + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
}

<!-- STATS -->
<div class="admin-content">

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <div class="col-md-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="bi bi-airplane"></i>
                </div>
                <div class="stat-info">
                    <p>Total Flights</p>
                    <h3>@Model.TotalFlights</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="bi bi-ticket-perforated"></i>
                </div>
                <div class="stat-info">
                    <p>Total Bookings</p>
                    <h3>@Model.TotalBookings</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon gold">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div class="stat-info">
                    <p>Revenue</p>
                    <h3>@Model.TotalRevenue.ToString("0.00")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="bi bi-people"></i>
                </div>
                <div class="stat-info">
                    <p>Total Users</p>
                    <h3>@Model.TotalUsers</h3>
                </div>
            </div>
        </div>

    </div>

    <!-- RECENT BOOKINGS -->
    <div class="card-custom">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title-custom mb-0">Recent Bookings</h5>
            <a href="/Admin/Booking" class="btn btn-sm btn-light rounded-pill px-3">
                View All
            </a>
        </div>

        @if (Model.LatestBookings != null && Model.LatestBookings.Any())
        {
            <div class="table-responsive">
                <table class="table table-custom mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.LatestBookings)
                        {
                            <tr>
                                <td>
                                    @(item.User?.FName ?? "Unknown")
                                </td>

                                <td>
                                    @item.BookingDate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @item.TotalPrice.ToString("0.00")
                                </td>

                                <td>
                                    @if (item.Status == "Confirmed")
                                    {
                                        <span class="badge badge-soft-success">Confirmed</span>
                                    }
                                    else if (item.Status == "Pending")
                                    {
                                        <span class="badge badge-soft-warning">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="text-muted">No bookings found</div>
        }

    </div>

</div>