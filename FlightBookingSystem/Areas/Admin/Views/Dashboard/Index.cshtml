@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageId"] = "dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div class="page-title-block">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back — here's what's happening today.</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/Flight/Create" class="btn btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" /></svg>
            New Flight
        </a>
    </div>
</div>

<!-- KPI CARDS -->
<div class="kpi-grid">

    <div class="kpi-card accent">
        <div class="kpi-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z" /></svg>
        </div>
        <div class="kpi-label">Flights Today</div>
        <div class="kpi-value">@(ViewBag.FlightsToday ?? 142)</div>
        <div class="kpi-delta up">↑ 8 more than yesterday</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.52 15.52 0 12 0S6 2.52 6 4.64c0 .48.11.92.18 1.36H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-8-4c1.9 0 3.33 1.06 3.67 2.64H8.33C8.67 3.06 10.1 2 12 2z" /></svg>
        </div>
        <div class="kpi-label">Active Bookings</div>
        <div class="kpi-value">@(ViewBag.ActiveBookings ?? "3,847")</div>
        <div class="kpi-delta up">↑ 12.4% this week</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" /></svg>
        </div>
        <div class="kpi-label">Revenue (EGP)</div>
        <div class="kpi-value">@(ViewBag.Revenue ?? "841K")</div>
        <div class="kpi-delta up">↑ 6.1% vs last month</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" /></svg>
        </div>
        <div class="kpi-label">Delayed Flights</div>
        <div class="kpi-value">@(ViewBag.DelayedFlights ?? 7)</div>
        <div class="kpi-delta down">↑ 3 above average</div>
    </div>

</div>

<!-- MID ROW: chart + live flights -->
<div class="grid-2-1" style="margin-bottom:16px;">

    <!-- Bookings chart -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Bookings This Week</span>
            <span class="badge badge-purple">Live</span>
        </div>
        <div class="card-body">
            <div class="mini-bar-chart" id="bookingsChart">
                <div class="mini-bar" style="height:42%" data-day="Mon" data-val="210"></div>
                <div class="mini-bar" style="height:57%" data-day="Tue" data-val="284"></div>
                <div class="mini-bar" style="height:36%" data-day="Wed" data-val="180"></div>
                <div class="mini-bar" style="height:72%" data-day="Thu" data-val="360"></div>
                <div class="mini-bar active" style="height:91%" data-day="Fri" data-val="455"></div>
                <div class="mini-bar active" style="height:85%" data-day="Sat" data-val="425"></div>
                <div class="mini-bar" style="height:62%" data-day="Sun" data-val="310"></div>
            </div>
            <div class="chart-labels">
                <span class="chart-label">Mon</span>
                <span class="chart-label">Tue</span>
                <span class="chart-label">Wed</span>
                <span class="chart-label">Thu</span>
                <span class="chart-label">Fri</span>
                <span class="chart-label">Sat</span>
                <span class="chart-label">Sun</span>
            </div>
            <div style="display:flex;gap:20px;margin-top:14px;">
                <div>
                    <div style="font-size:11px;color:var(--text-muted);margin-bottom:2px;">Total this week</div>
                    <div style="font-family:var(--font-display);font-size:20px;font-weight:700;color:var(--text-primary);">2,224</div>
                </div>
                <div>
                    <div style="font-size:11px;color:var(--text-muted);margin-bottom:2px;">Avg daily</div>
                    <div style="font-family:var(--font-display);font-size:20px;font-weight:700;color:var(--text-primary);">318</div>
                </div>
                <div>
                    <div style="font-size:11px;color:var(--text-muted);margin-bottom:2px;">Peak day</div>
                    <div style="font-family:var(--font-display);font-size:20px;font-weight:700;color:var(--p600);">Friday</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Live flights -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Live Flights</span>
            <span class="badge badge-green">14 active</span>
        </div>
        <div class="card-body" style="padding:10px 14px;">

            @* Replace with real data: @foreach(var f in Model.LiveFlights) *@
            <div class="flight-status-row">
                <div class="fs-dot on-time"></div>
                <span class="fs-code">MS401</span>
                <span class="fs-route">CAI → HRG</span>
                <span class="fs-time">09:15</span>
                <span class="badge badge-green">On time</span>
            </div>
            <div class="flight-status-row">
                <div class="fs-dot delayed"></div>
                <span class="fs-code">MS215</span>
                <span class="fs-route">CAI → LXR</span>
                <span class="fs-time">10:40</span>
                <span class="badge badge-amber">Delayed</span>
            </div>
            <div class="flight-status-row">
                <div class="fs-dot on-time"></div>
                <span class="fs-code">MS380</span>
                <span class="fs-route">HRG → CAI</span>
                <span class="fs-time">11:05</span>
                <span class="badge badge-green">On time</span>
            </div>
            <div class="flight-status-row">
                <div class="fs-dot cancelled"></div>
                <span class="fs-code">MS112</span>
                <span class="fs-route">CAI → SSH</span>
                <span class="fs-time">12:20</span>
                <span class="badge badge-red">Cancelled</span>
            </div>
            <div class="flight-status-row">
                <div class="fs-dot boarding"></div>
                <span class="fs-code">MS550</span>
                <span class="fs-route">ASW → CAI</span>
                <span class="fs-time">13:00</span>
                <span class="badge badge-purple">Boarding</span>
            </div>

            <a href="/Admin/Flight" class="btn btn-secondary btn-sm" style="width:100%;margin-top:12px;justify-content:center;">
                View all flights →
            </a>
        </div>
    </div>

</div>

<!-- BOTTOM ROW: 3 stat cards -->
<div class="grid-3" style="margin-bottom:16px;">

    <div class="card">
        <div class="card-body">
            <div class="stat-row">
                <div class="stat-icon-box">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M7 13c1.66 0 3-1.34 3-3S8.66 7 7 7s-3 1.34-3 3 1.34 3 3 3zm12-6h-8v7H3V5H1v15h2v-3h18v3h2v-9c0-2.21-1.79-4-4-4z" /></svg>
                </div>
                <div class="stat-text-block">
                    <div class="stat-number">78%</div>
                    <div class="stat-desc">Avg seat occupancy</div>
                    <div class="progress-track" style="margin-top:7px;">
                        <div class="progress-fill" style="width:78%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="stat-row">
                <div class="stat-icon-box green">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l3.09 6.26L22 8.27l-5 4.87 1.18 6.88L12 16.9l-6.18 3.12L7 13.14 2 8.27l6.91-1.01L12 1z" /></svg>
                </div>
                <div class="stat-text-block">
                    <div class="stat-number">12,340</div>
                    <div class="stat-desc">Reward points issued</div>
                    <div class="progress-track" style="margin-top:7px;">
                        <div class="progress-fill green" style="width:62%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="stat-row">
                <div class="stat-icon-box amber">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" /></svg>
                </div>
                <div class="stat-text-block">
                    <div class="stat-number">98.2%</div>
                    <div class="stat-desc">Payment success rate</div>
                    <div class="progress-track" style="margin-top:7px;">
                        <div class="progress-fill amber" style="width:98%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- BOTTOM: Recent bookings table -->
<div class="card">
    <div class="card-header">
        <span class="card-title">Recent Bookings</span>
        <a href="/Admin/Booking" class="btn btn-secondary btn-sm">View all</a>
    </div>
    <div class="table-wrap" style="border:none;border-radius:0;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Booking #</th>
                    <th>Passenger</th>
                    <th>Flight</th>
                    <th>Route</th>
                    <th>Class</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @* Replace with: @foreach(var b in Model.RecentBookings) *@
                <tr>
                    <td><span class="cell-mono">BK-00412</span></td>
                    <td>Ahmed Hassan</td>
                    <td><span class="cell-mono">MS401</span></td>
                    <td>CAI → HRG</td>
                    <td><span class="badge badge-purple">Business</span></td>
                    <td>EGP 3,200</td>
                    <td><span class="badge badge-green">Confirmed</span></td>
                    <td><a href="/Admin/Booking/Details/412" class="btn btn-secondary btn-sm">View</a></td>
                </tr>
                <tr>
                    <td><span class="cell-mono">BK-00411</span></td>
                    <td>Fatma Samir</td>
                    <td><span class="cell-mono">MS215</span></td>
                    <td>CAI → LXR</td>
                    <td><span class="badge badge-gray">Economy</span></td>
                    <td>EGP 890</td>
                    <td><span class="badge badge-amber">Pending</span></td>
                    <td><a href="/Admin/Booking/Details/411" class="btn btn-secondary btn-sm">View</a></td>
                </tr>
                <tr>
                    <td><span class="cell-mono">BK-00410</span></td>
                    <td>Khaled Nour</td>
                    <td><span class="cell-mono">MS112</span></td>
                    <td>CAI → SSH</td>
                    <td><span class="badge badge-gray">Economy</span></td>
                    <td>EGP 1,050</td>
                    <td><span class="badge badge-red">Cancelled</span></td>
                    <td><a href="/Admin/Booking/Details/410" class="btn btn-secondary btn-sm">View</a></td>
                </tr>
                <tr>
                    <td><span class="cell-mono">BK-00409</span></td>
                    <td>Sara Mahmoud</td>
                    <td><span class="cell-mono">MS550</span></td>
                    <td>ASW → CAI</td>
                    <td><span class="badge badge-purple">Business</span></td>
                    <td>EGP 4,700</td>
                    <td><span class="badge badge-green">Confirmed</span></td>
                    <td><a href="/Admin/Booking/Details/409" class="btn btn-secondary btn-sm">View</a></td>
                </tr>
                <tr>
                    <td><span class="cell-mono">BK-00408</span></td>
                    <td>Omar Adel</td>
                    <td><span class="cell-mono">MS380</span></td>
                    <td>HRG → CAI</td>
                    <td><span class="badge badge-gray">Economy</span></td>
                    <td>EGP 760</td>
                    <td><span class="badge badge-green">Confirmed</span></td>
                    <td><a href="/Admin/Booking/Details/408" class="btn btn-secondary btn-sm">View</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
