@model Flight

@{
    ViewData["Title"] = "Edit Flight";
    ViewData["PageId"] = "flights";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Edit Flight</h4>
        <a href="/Admin/Flight" class="btn btn-light rounded-pill px-4">Back</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-area="Admin"
                  asp-controller="Flight"
                  asp-action="Edit"
                  method="post"
                  class="row g-3">

                <input type="hidden" asp-for="FlightId" />

                <div class="col-md-6">
                    <label>Flight Number</label>
                    <input asp-for="FlightNum" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label>Status</label>
                    <select asp-for="Status" class="form-select">
                        <option>Active</option>
                        <option>Cancelled</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label>Departure Airport</label>
                    <select asp-for="DepartureAirportId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.Airports, "AirportId", "Name", Model.DepartureAirportId))">
                    </select>
                </div>

                <div class="col-md-6">
                    <label>Arrival Airport</label>
                    <select asp-for="ArrivalAirportId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.Airports, "AirportId", "Name", Model.ArrivalAirportId))">
                    </select>
                </div>

                <div class="col-md-6">
                    <label>Departure Time</label>
                    <input asp-for="DepartureTime" type="datetime-local"
                           value="@Model.DepartureTime.ToString("yyyy-MM-ddTHH:mm")"
                           class="form-control" />
                </div>

                <div class="col-md-6">
                    <label>Arrival Time</label>
                    <input asp-for="ArrivalTime" type="datetime-local"
                           value="@Model.ArrivalTime.ToString("yyyy-MM-ddTHH:mm")"
                           class="form-control" />
                </div>

                <div class="col-md-6">
                    <label>Base Price</label>
                    <input asp-for="BasePrice" type="number" step="0.01" class="form-control" />
                </div>

                <div class="col-12 text-end mt-4">
                    <button class="btn btn-dark rounded-pill px-4">Update</button>
                </div>

            </form>

        </div>
    </div>

</div>
