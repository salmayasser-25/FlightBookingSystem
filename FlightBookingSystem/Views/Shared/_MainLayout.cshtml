<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SkyAdmin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/flight/style.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- NAVBAR -->
    <header class="site-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" href="index.html">
                    <div class="logo-wrapper">
                        <div class="logo-icon-custom" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; margin-right: 10px;">
                            <img src="globe.png" alt="AeroFly Logo" style="width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));">
                        </div>
                        <div class="logo-text">
                            <span class="logo-main">AeroFly</span>
                            <span class="logo-tagline">premium airways</span>
                        </div>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <i class="bi bi-list"></i>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About Us</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="FlightStatus">Flight Status</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="MyTrips">My Trips</a></li>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link btn-outline-primary-custom" asp-area="Identity" asp-controller="Account" asp-action="Login">Sign In</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn-primary-solid" asp-area="Identity" asp-controller="Account" asp-action="Register">Join AeroFly+</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @RenderBody()

    <!-- ===================== FOOTER ===================== -->
    <footer class="site-footer">
        <div class="container">
            <div class="row gy-5">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <div class="footer-logo-icon" style="background: transparent;">
                            <img src="globe.png" alt="AeroFly Logo" style="width: 44px; height: 44px; object-fit: contain;">
                        </div>
                        <div>
                            <div class="footer-logo-name">AeroFly</div>
                            <div class="footer-logo-sub">premium airways</div>
                        </div>
                    </div>
                    <p class="footer-description">Redefining air travel with elegance, reliability, and world-class service since 2012.</p>
                    <div class="footer-social">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-twitter-x"></i></a>
                        <a href="#"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h5>Company</h5>
                    <ul>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press Room</a></li>
                        <li><a href="#">Sustainability</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5>Services</h5>
                    <ul>
                        <li><a href="#">Flight Status</a></li>
                        <li><a href="#">Baggage Info</a></li>
                        <li><a href="#">Travel Advisory</a></li>
                        <li><a href="#">Group Travel</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h5>Newsletter</h5>
                    <p class="newsletter-text">Subscribe for exclusive deals and travel inspiration.</p>
                    <div class="newsletter-form">
                        <input type="email" placeholder="Your email address">
                        <button><i class="bi bi-send-fill"></i></button>
                    </div>
                    <div class="footer-contact mt-3">
                        <p><i class="bi bi-telephone-fill"></i> +1 (888) 759-7284</p>
                        <p><i class="bi bi-envelope-fill"></i> premium@aerofly.com</p>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 AeroFly Airways. All rights reserved. A premium airline experience.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/flight/script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
