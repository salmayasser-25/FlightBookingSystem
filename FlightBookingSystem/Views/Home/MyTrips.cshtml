@{
    ViewData["Title"] = "My Trips";
}

<section class="section-pad">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge">Member Portal</span>
            <h2 class="section-title">My <span class="text-accent">Trips</span></h2>
            <p class="section-subtitle">Manage your bookings, check-in, and view your AeroFly+ points.</p>
        </div>
        
        <div class="row justify-content-center mt-5">
            <div class="col-lg-8">
                <div class="search-card text-center py-5">
                    <i class="bi bi-airplane-engines fs-1 text-accent mb-3 d-block"></i>
                    <h4>No upcoming trips found</h4>
                    <p class="text-muted mb-4">Start your next adventure by searching for a flight.</p>
                    <a asp-action="Index" class="btn-search-primary">Book a Flight</a>
                </div>
            </div>
        </div>
    </div>
</section>
