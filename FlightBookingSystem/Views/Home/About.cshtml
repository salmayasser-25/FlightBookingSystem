@{
    ViewData["Title"] = "About Us";
}

<section class="section-pad">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge">About AeroFly</span>
            <h2 class="section-title">Redefining <span class="text-accent">Air Travel</span></h2>
            <p class="section-subtitle">Since 2012, we have been committed to providing a premium travel experience with elegance and world-class service.</p>
        </div>
        
        <div class="row align-items-center mt-5">
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1540962351504-03099e0a754b?w=600&h=400&fit=crop" class="img-fluid rounded-4 shadow-lg" alt="About Us">
            </div>
            <div class="col-lg-6 mt-4 mt-lg-0">
                <h3 class="mb-4">Our Vision</h3>
                <p class="text-muted">At AeroFly, we believe that the journey is just as important as the destination. Our fleet of modern aircraft and dedicated crew ensure that every passenger enjoys unparalleled comfort and safety.</p>
                <p class="text-muted">We continuously innovate our services, from our state-of-the-art booking system to our Michelin-starred onboard dining, to meet the needs of the modern traveler.</p>
            </div>
        </div>
    </div>
</section>
