@model DeleteAccountViewModel
@{
    ViewData["Title"] = "Delete Account";
}

<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="mb-4">
                <h1 class="h3 mb-1 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>Delete Your Account
                </h1>
                <p class="text-muted mb-0">This action is permanent and cannot be undone.</p>
            </div>

            <div class="alert alert-warning">
                <h5 class="alert-heading"><i class="bi bi-info-circle me-1"></i>Before you continue</h5>
                <ul class="mb-0 small">
                    <li>Your profile, reward points, and booking history will be permanently removed.</li>
                    <li>You won't be able to recover this account.</li>
                    <li>Active bookings (not cancelled or completed) must be cancelled first.</li>
                </ul>
            </div>

            @if (Model.ActiveBookingCount > 0)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-x-octagon me-1"></i>
                    You currently have <strong>@Model.ActiveBookingCount</strong> active booking(s).
                    Please <a asp-action="MyBookings" class="alert-link">review your bookings</a> and cancel them before continuing.
                </div>
            }

            <div class="card shadow-sm border-danger">
                <div class="card-body p-4">
                    <form asp-action="DeleteAccount" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                            <div class="form-text">For your safety, please re-enter your password.</div>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="ConfirmDelete" class="form-check-input" />
                            <label asp-for="ConfirmDelete" class="form-check-label"></label>
                            <div>
                                <span asp-validation-for="ConfirmDelete" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Profile" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Keep My Account
                            </a>
                            <button type="submit" class="btn btn-danger" @(Model.ActiveBookingCount > 0 ? "disabled" : "")>
                                <i class="bi bi-trash me-1"></i> Delete My Account
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
