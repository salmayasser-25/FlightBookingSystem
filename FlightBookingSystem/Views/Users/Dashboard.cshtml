@model UserDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

@section Styles {
    <style>
        body { background: var(--gray-50); }
        .page-header {
            padding: 100px 0 30px;
            background: var(--primary-deep-blue);
        }
        .dashboard-wrapper { padding: 40px 0 80px; }
        .sidebar {
            background: white;
            border-radius: 16px;
            padding: 20px 0;
            box-shadow: var(--shadow-sm);
            height: 100%;
        }
        .sidebar-user {
            text-align: center;
            padding: 0 20px 20px;
            border-bottom: 1px solid var(--gray-200);
            margin-bottom: 20px;
        }
        .user-avatar {
            width: 80px; height: 80px;
            background: var(--primary-sky);
            color: white;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; font-weight: 700;
            margin: 0 auto 15px;
        }
        .sidebar-menu { list-style: none; padding: 0; margin: 0; }
        .sidebar-menu li a {
            display: flex; align-items: center;
            padding: 12px 24px;
            color: var(--gray-700);
            text-decoration: none;
            font-weight: 600;
            transition: all var(--transition-fast);
        }
        .sidebar-menu li a i {
            margin-right: 12px;
            font-size: 1.2rem;
            color: var(--gray-500);
        }
        .sidebar-menu li a:hover, .sidebar-menu li a.active {
            background: rgba(45, 122, 159, 0.05);
            color: var(--primary-sky);
            border-right: 3px solid var(--primary-sky);
        }
        .sidebar-menu li a.active i { color: var(--primary-sky); }
        .dash-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow-sm);
            margin-bottom: 24px;
        }
        .dash-card-title {
            font-family: 'Gelasio', sans-serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary-deep-blue);
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .points-card {
            background: linear-gradient(135deg, var(--accent-gold) 0%, #B8942E 100%);
            color: white;
            border-radius: 16px;
            padding: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-md);
            margin-bottom: 24px;
        }
        .points-number {
            font-family: 'Gelasio', sans-serif;
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1;
        }
        .points-label {
            font-size: 0.9rem;
            font-weight: 600;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .table-flights th {
            color: var(--gray-500);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            border-bottom: 1px solid var(--gray-200);
            padding-bottom: 15px;
        }
        .table-flights td {
            padding: 15px 0;
            vertical-align: middle;
            border-bottom: 1px solid var(--gray-100);
        }
        .flight-route { font-weight: 700; color: var(--primary-deep-blue); }
        .badge-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
        }
        .badge-upcoming { background: rgba(45, 122, 159, 0.1); color: var(--primary-sky); }
        .badge-completed { background: rgba(40, 167, 69, 0.1); color: #28a745; }
        .badge-cancelled { background: rgba(220, 53, 69, 0.1); color: #dc3545; }
        .badge-pending { background: rgba(255, 193, 7, 0.15); color: #b8860b; }
        .badge-confirmed { background: rgba(13, 110, 253, 0.1); color: #0d6efd; }
    </style>
}

<section class="page-header">
    <div class="container">
        <h2 class="text-white mb-0" style="font-family: 'Gelasio'; font-weight: 800;">My Dashboard</h2>
    </div>
</section>

<section class="dashboard-wrapper">
    <div class="container">
        <div class="row">

            <div class="col-lg-3 mb-4">
                <div class="sidebar animate-fade-up">
                    <div class="sidebar-user">
                        <div class="user-avatar">@(string.IsNullOrEmpty(Model.Initials) ? "?" : Model.Initials)</div>
                        <h5 class="fw-bold mb-1" style="color: var(--primary-deep-blue);">@Model.FullName</h5>
                        <p class="text-muted small mb-0">AeroFly+ Member</p>
                    </div>
                    <ul class="sidebar-menu">
                        <li><a asp-controller="Users" asp-action="Dashboard" class="active"><i class="bi bi-grid-1x2"></i> Overview</a></li>
                        <li><a asp-controller="Users" asp-action="MyBookings"><i class="bi bi-airplane"></i> My Flights</a></li>
                        <li><a asp-controller="Users" asp-action="Dashboard"><i class="bi bi-star"></i> Reward Points</a></li>
                        <li><a asp-controller="Users" asp-action="Profile"><i class="bi bi-person"></i> Profile Settings</a></li>
                        <li><a asp-controller="Users" asp-action="DeleteAccount"><i class="bi bi-trash"></i> Delete Account</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-9">

                <div class="row">
                    <div class="col-md-6">
                        <div class="points-card animate-fade-up">
                            <div>
                                <div class="points-label mb-1">Available Points</div>
                                <div class="points-number">@Model.RewardPoints.ToString("N0")</div>
                            </div>
                            <i class="bi bi-award-fill" style="font-size: 3rem; opacity: 0.5;"></i>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="dash-card animate-fade-up d-flex align-items-center h-100 mt-0">
                            <div class="d-flex align-items-center w-100 justify-content-around text-center">
                                <div>
                                    <div class="fs-2 fw-bold text-primary">@Model.FlightsTaken</div>
                                    <div class="small text-muted fw-bold">FLIGHTS TAKEN</div>
                                </div>
                                <div style="width: 1px; height: 40px; background: var(--gray-200);"></div>
                                <div>
                                    <div class="fs-2 fw-bold text-success">@Model.CitiesVisited</div>
                                    <div class="small text-muted fw-bold">CITIES VISITED</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="dash-card animate-fade-up">
                    <div class="dash-card-title">
                        Recent &amp; Upcoming Flights
                        <a asp-controller="Users" asp-action="MyBookings" class="text-primary fs-6 fw-normal text-decoration-none">View All</a>
                    </div>
                    <div class="table-responsive">
                        @if (Model.RecentFlights.Count == 0)
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-airplane display-5 d-block mb-2"></i>
                                <p class="mb-0">No flights yet. Book your first trip to see it here.</p>
                            </div>
                        }
                        else
                        {
                            <table class="table table-borderless table-flights mb-0">
                                <thead>
                                    <tr>
                                        <th>Route</th>
                                        <th>Date</th>
                                        <th>PNR</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in Model.RecentFlights)
                                    {
                                        var s = (f.Status ?? "").ToLowerInvariant();
                                        var (cls, label) = s switch
                                        {
                                            "upcoming" => ("badge-upcoming", "Upcoming"),
                                            "confirmed" => ("badge-confirmed", "Confirmed"),
                                            "completed" => ("badge-completed", "Completed"),
                                            "cancelled" => ("badge-cancelled", "Cancelled"),
                                            "pending" => ("badge-pending", "Pending"),
                                            _ => ("badge-upcoming", string.IsNullOrEmpty(f.Status) ? "—" : f.Status)
                                        };
                                        <tr>
                                            <td>
                                                <div class="flight-route">@f.DepartureCode <i class="bi bi-arrow-right mx-1 text-muted"></i> @f.ArrivalCode</div>
                                                @if (!string.IsNullOrEmpty(f.FlightNumber))
                                                {
                                                    <div class="small text-muted">AeroFly @f.FlightNumber</div>
                                                }
                                            </td>
                                            <td class="fw-bold text-dark">@f.BookingDate.ToString("dd MMM yyyy")</td>
                                            <td class="fw-bold">@f.Pnr</td>
                                            <td><span class="badge-status @cls">@label</span></td>
                                            <td><a asp-controller="Users" asp-action="MyBookings" class="btn btn-sm btn-outline-primary rounded-pill px-3">Manage</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
