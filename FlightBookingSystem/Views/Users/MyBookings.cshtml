@model MyBookingsViewModel
@{
    ViewData["Title"] = "My Bookings";
}

<section class="container py-5">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">My Bookings</h1>
            <p class="text-muted mb-0">@Model.TotalCount booking(s) on your account.</p>
        </div>
        <a asp-action="Profile" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Profile
        </a>
    </div>

    @if (Model.TotalCount == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-suitcase display-4 text-muted mb-3 d-block"></i>
                <h5 class="mb-2">No bookings yet</h5>
                <p class="text-muted mb-4">When you book a flight, it'll show up here.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-airplane me-1"></i> Find Flights
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Booking</th>
                            <th scope="col">Date</th>
                            <th scope="col">Route</th>
                            <th scope="col" class="text-center">Passengers</th>
                            <th scope="col" class="text-center">Tickets</th>
                            <th scope="col" class="text-end">Total</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Bookings)
                        {
                            <tr>
                                <td><span class="fw-semibold">#@b.BookingId</span></td>
                                <td>@b.BookingDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(b.RouteSummary))
                                    {
                                        <span class="text-nowrap">@b.RouteSummary</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-center">@b.PassengerCount</td>
                                <td class="text-center">@b.TicketCount</td>
                                <td class="text-end">@b.TotalPrice.ToString("C")</td>
                                <td>
                                    @{
                                        var s = (b.Status ?? "").ToLowerInvariant();
                                        var (cls, label) = s switch
                                        {
                                            "confirmed" => ("bg-success", "Confirmed"),
                                            "completed" => ("bg-secondary", "Completed"),
                                            "cancelled" => ("bg-danger", "Cancelled"),
                                            "pending" => ("bg-warning text-dark", "Pending"),
                                            _ => ("bg-light text-dark", b.Status ?? "Unknown")
                                        };
                                    }
                                    <span class="badge @cls">@label</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</section>
