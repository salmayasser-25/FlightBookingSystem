@model EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="mb-4">
                <h1 class="h3 mb-1">Edit Profile</h1>
                <p class="text-muted mb-0">Update your personal information.</p>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="FName" class="form-label"></label>
                            <input asp-for="FName" class="form-control" autocomplete="given-name" />
                            <span asp-validation-for="FName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LName" class="form-label"></label>
                            <input asp-for="LName" class="form-control" autocomplete="family-name" />
                            <span asp-validation-for="LName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" disabled readonly />
                            <div class="form-text">To change your email, please contact support.</div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Profile" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
